APP_NAME=LokaFi
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lokafi
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173
FRONTEND_HTTPS_URL=https://localhost:5173
LOKAFI_DEMO_MERCHANT_PUBLIC_KEY=
LOKAFI_DEMO_CUSTOMER_PUBLIC_KEY=

BRANKAS_ENV=sandbox
BRANKAS_API_KEY=
BRANKAS_CLIENT_ID=
BRANKAS_CLIENT_SECRET=
BRANKAS_BASE_URL=https://statement.sandbox.bnk.to
BRANKAS_CALLBACK_URL=http://127.0.0.1:8000/api/bank-connections/callback

AI_ENABLED=false
AI_PROVIDER=
AI_API_KEY=
AI_API_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=20
AI_FINANCIAL_INSIGHTS_ENABLED=false
AI_FINANCIAL_INSIGHT_MODEL=
AI_FINANCIAL_INSIGHT_PROMPT_VERSION=financial_insight_id_v2
AI_FINANCIAL_INSIGHT_TIMEOUT_SECONDS=30
AI_FINANCIAL_INSIGHT_CACHE_HOURS=24
